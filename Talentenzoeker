// ===== COUNTER =====
function updateCounter() {
  const phase = state.phase;
  let count = 0;
  if (phase === 1) count = state.phase1Selected.length + (state.customSelected1 ? 1 : 0);
  else if (phase === 2) count = state.phase2Selected.length + (state.customSelected2 ? 1 : 0);
  else if (phase === 3) count = state.phase3Selected.length + (state.customSelected3 ? 1 : 0);

  const max = phaseMax[phase] || 10;
  const el = document.getElementById('counterNum');
  el.textContent = count + ' / ' + max;
  el.classList.toggle('warning', count > max);
}

