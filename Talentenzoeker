// ===== RENDER =====
function renderPhase(phase) {
  // Hide all phases
  document.querySelectorAll('.phase').forEach(el => el.classList.remove('active'));

  if (phase === 1) {
    document.getElementById('phase1').classList.add('active');
    renderGrid1();
    updateCounter();
  } else if (phase === 2) {
    document.getElementById('phase2').classList.add('active');
    renderGrid2();
    updateCounter();
  } else if (phase === 3) {
    document.getElementById('phase3').classList.add('active');
    renderGrid3();
    updateCounter();
  } else {
    document.getElementById('phaseResult').classList.add('active');
    renderResult();
    // info btn handled per phase
  }

  
}

// ===== GRID 1 =====
function renderGrid1() {
  const grid = document.getElementById('grid1');
  grid.innerHTML = '';

  TALENTS.forEach(t => {
    const selected = state.phase1Selected.includes(t.id);
    const card = createFlipCard(t, selected, () => togglePhase1(t.id));
    grid.appendChild(card);
  });

  // Custom card
  grid.appendChild(createCustomCard(1));
}

function createFlipCard(t, selected, onToggle) {
  const div = document.createElement('div');
  div.className = 'flip-card' + (selected ? ' selected' : '');
  div.dataset.id = t.id;

  const nameMatch = t.name.match(/^(.*?)\s*(\(.*\))\s*$/);
  const nameMain = nameMatch ? nameMatch[1] : t.name;
  const nameSub = nameMatch ? nameMatch[2] : '';
  div.innerHTML = `
    <div class="flip-card-inner">
      <div class="flip-front">
        <span class="value-name">${nameMain}${nameSub ? `<br><span class="talent-sub">${nameSub.replace(/[()]/g, '')}</span>` : ''}</span>
      </div>
      <div class="flip-back"><span class="value-desc">${t.kort}</span></div>
    </div>`;

  let pressTimer = null;
  let isLongPress = false;
  let touchHandled = false;

  // TOUCH (mobiel)
  div.addEventListener('touchstart', (e) => {
    isLongPress = false;
    touchHandled = false;
    pressTimer = setTimeout(() => {
      isLongPress = true;
      div.classList.toggle('flipped');
    }, 500);
  }, { passive: true });

  div.addEventListener('touchmove', () => {
    clearTimeout(pressTimer);
    isLongPress = false;
  }, { passive: true });

  div.addEventListener('touchend', (e) => {
    clearTimeout(pressTimer);
    touchHandled = true;
    if (!isLongPress) {
      e.preventDefault();
      onToggle();
    }
    isLongPress = false;
  });

  // MOUSE (desktop) — hover via CSS, click = selecteren
  div.addEventListener('click', (e) => {
    if (touchHandled) { touchHandled = false; return; }
    onToggle();
  });

  return div;
}

function createCustomCard(phase) {
  const div = document.createElement('div');
  const isSelected = phase === 1 ? state.customSelected1 : (phase === 2 ? state.customSelected2 : state.customSelected3);
  div.className = 'custom-card' + (isSelected ? ' selected' : '');
  div.dataset.custom = phase;

  const input = document.createElement('input');
  input.type = 'text';
  input.className = 'custom-input';
  input.placeholder = 'Hier jouw eigen talent';
  input.value = state.customTalent || '';
  input.maxLength = 40;
  if (phase > 1) {
    input.readOnly = true;
    input.style.cursor = 'pointer';
  }

  input.addEventListener('input', (e) => {
    state.customTalent = e.target.value;
    saveState();
  });

  input.addEventListener('click', (e) => {
    // In phase 2/3, input is read-only so clicking it should toggle selection
    if (phase > 1) {
      e.stopPropagation();
      if (state.customTalent.trim()) toggleCustom(phase, div);
      return;
    }
    e.stopPropagation();
  });

  div.appendChild(input);

  div.addEventListener('click', (e) => {
    if (e.target === input) return;
    if (!state.customTalent.trim()) {
      input.focus();
      return;
    }
    toggleCustom(phase, div);
  });

  // Also toggle when input is blurred with value and card is clicked
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      input.blur();
      if (state.customTalent.trim()) {
        toggleCustom(phase, div);
      }
    }
  });

  return div;
}

function toggleCustom(phase, div) {
  const maxMap = { 1: 10, 2: 6, 3: 4 };
  const selKey = ['customSelected1', 'customSelected2', 'customSelected3'][phase - 1];
  const phaseSelKey = ['phase1Selected', 'phase2Selected', 'phase3Selected'][phase - 1];
  const max = maxMap[phase];

  if (!state[selKey]) {
    const count = state[phaseSelKey].length + (state[selKey] ? 1 : 0);
    if (count >= max) { showTooManyPopup(); return; }
    state[selKey] = true;
  } else {
    state[selKey] = false;
  }
  div.classList.toggle('selected', state[selKey]);
  updateCounter();
  saveState();
}

function togglePhase1(id) {
  const idx = state.phase1Selected.indexOf(id);
  const customCount = state.customSelected1 ? 1 : 0;
  if (idx === -1) {
    if (state.phase1Selected.length + customCount >= 10) {
      showTooManyPopup(); return;
    }
    state.phase1Selected.push(id);
  } else {
    state.phase1Selected.splice(idx, 1);
  }
  saveState();
  // Update card visual
  const card = document.querySelector(`#grid1 .flip-card[data-id="${id}"]`);
  if (card) card.classList.toggle('selected', state.phase1Selected.includes(id));
  updateCounter();
}

