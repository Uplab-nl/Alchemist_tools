function copyResults() {
  const talents = state.phase3Selected.map(id => TALENTS.find(t => t.id === id)).filter(Boolean);
  let text = 'MIJN KERNTALENTEN\n' + '='.repeat(40) + '\n\n';
  talents.forEach((t, i) => {
    text += `${i+1}. ${t.name}\n\n${t.lang}\n\n` + '-'.repeat(40) + '\n\n';
  });
  if (state.customSelected3 && state.customTalent.trim()) {
    text += `${talents.length+1}. ${state.customTalent}\n\nDit is jouw eigen talent — beschrijf wat het voor jou betekent.\n\n`;
  }

  function doFallback() {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;top:0;left:0;opacity:0;pointer-events:none;';
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    try {
      document.execCommand('copy');
      markCopied();
    } catch(e) {
      alert('Kopiëren niet gelukt. Selecteer de tekst hieronder en kopieer handmatig.');
    }
    document.body.removeChild(ta);
  }

  function markCopied() {
    const btn = document.getElementById('btnCopy');
    btn.textContent = '✓ Gekopieerd!';
    btn.classList.add('copied');
    setTimeout(() => {
      btn.textContent = 'Kopieer kerntalenten';
      btn.classList.remove('copied');
    }, 3000);
  }

  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).then(markCopied).catch(doFallback);
  } else {
    doFallback();
  }
}

// ===== POPUPS =====
function showPopup(title, body, actions) {
  document.getElementById('popupTitle').textContent = title;
  const bodyEl = document.getElementById('popupBody');
  bodyEl.innerHTML = body.split('\n\n').map(p => p.trim() ? '<p>' + p.replace(/\n/g,'<br>') + '</p>' : '').join('');

  const actionsEl = document.getElementById('popupActions');
  actionsEl.innerHTML = '';
  (actions || []).forEach(a => {
    const btn = document.createElement('button');
    btn.className = a.primary ? 'popup-btn' : 'popup-btn-secondary';
    btn.textContent = a.label;
    btn.onclick = new Function(a.fn);
    actionsEl.appendChild(btn);
  });

  document.getElementById('overlay').classList.add('active');
}

function closePopup() {
  document.getElementById('overlay').classList.remove('active');
}
window.closePopup = closePopup;

