    ]);
  }
});

// Reset button
document.getElementById('btnReset').addEventListener('click', () => {
  showPopup('Opnieuw beginnen?',
    'Weet je zeker dat je opnieuw wilt beginnen? Alles wat je hebt geselecteerd wordt hiermee verwijderd.',
    [
      { label: 'Ja, opnieuw beginnen', fn: 'doReset()', primary: true },
      { label: 'Annuleren', fn: 'closePopup()', primary: false }
    ]);
});

function doReset() {
  state = { phase: 1, phase1Selected: [], phase2Selected: [], phase3Selected: [], customTalent: '', customSelected1: false, customSelected2: false, customSelected3: false };
  saveState();
  closePopup();
  
  renderPhase(1);
  showPopup(phaseInfo[1].title, phaseInfo[1].text, [
    { label: 'Aan de slag! 🚀', fn: 'closePopup()', primary: true }
  ]);
}
window.doReset = doReset;

// Close overlay on background click
document.getElementById('overlay').addEventListener('click', (e) => {
  if (e.target === document.getElementById('overlay')) closePopup();
});

// ===== START =====
init();
</script>
</body>
</html>
